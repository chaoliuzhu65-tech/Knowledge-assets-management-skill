# 知识资产管理助手配置文件

# ============================================
# 本地知识库配置
# ============================================

# 知识库根路径（扫描范围）
# 支持 ~ 扩展，如 ~/Documents 或 ~/WorkBuddy
KNOWLEDGE_BASE_PATH=~

# 最大扫描文件数（防止性能问题）
MAX_SCAN_FILES=500

# 扫描深度（0=仅当前目录，1=一级子目录...）
SCAN_DEPTH=6

# ============================================
# 外网检索配置
# ============================================

# 搜索引擎（可选：openai / bing / google）
SEARCH_ENGINE=bing

# 每个方向的检索结果数量（1-10）
SEARCH_RESULTS_COUNT=3

# ============================================
# 推送渠道配置
# ============================================

# 推送渠道（逗号分隔，留空则不推送）
# 可选值：dingtalk, feishu, local
CHANNELS=dingtalk,feishu

# 推送前是否要求确认
PUSH_CONFIRM=true

# ============================================
# AI 融合配置
# ============================================

# 每个文档提取的最大知识点数量
MAX_KNOWLEDGE_POINTS_PER_DOC=5

# 知识升级报告的最大章节长度（字符数）
MAX_SECTION_LENGTH=600

# ============================================
# 日志配置
# ============================================

# 是否显示详细日志
DEBUG=false

# 日志文件路径（留空则输出到控制台）
LOG_FILE=
