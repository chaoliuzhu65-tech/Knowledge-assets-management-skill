# 飞书应用配置

# 获取方式：
# 1. 访问飞书开放平台：https://open.feishu.cn
# 2. 创建企业自建应用，获取 App ID 和 App Secret
# 3. 在"权限管理"中申请以下权限：
#    - im:message:send_as_bot（发送消息）
#    - im:message（读取消息，如需读取历史）

# App ID
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxx

# App Secret
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 目标群聊 ID（Chat ID）
# 获取方式：在飞书群设置中查看群信息，复制 Chat ID
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxx

# （可选）目标用户 ID（私聊时使用）
FEISHU_USER_ID=
