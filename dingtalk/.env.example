# 钉钉机器人 Webhook 配置

# 获取方式：
# 1. 在钉钉群设置中添加"自定义机器人"
# 2. 选择"安全设置"为"自定义关键词"（推荐）或"加签"
# 3. 获取 Webhook URL，复制 access_token

# Webhook URL（仅复制 access_token 部分）
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_ACCESS_TOKEN

# 加签密钥（如果选择了"加签"安全设置）
# 如果使用"关键词"模式，留空即可
DINGTALK_WEBHOOK_SECRET=
